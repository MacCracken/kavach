    var sr = gate_apply(er, pol);
    assert_eq(ScanResult_verdict(sr), ScanVerdict.BLOCK, "stderr secret blocked");
    return 0;
}

fn test_credential_register_resolve() {
    test_group("credential_register");
    var p = credential_proxy_new();
    credential_proxy_register(p, "API_KEY", "sk-12345");
    var r = secret_ref_env("API_KEY", "OPENAI_API_KEY");
    var v = credential_proxy_resolve(p, r);
    assert(v != 0, "resolved");
    assert_eq(streq(v, "sk-12345"), 1, "value matches");

    var missing = secret_ref_stdin("NOPE");
    assert_eq(credential_proxy_resolve(p, missing), 0, "unknown returns 0");
    return 0;
}

fn test_credential_env_vars() {
    test_group("credential_env_vars");
    var p = credential_proxy_new();
    credential_proxy_register(p, "K1", "v1");
    credential_proxy_register(p, "K2", "v2");
    var refs = vec_new();
    vec_push(refs, secret_ref_env("K1", "MY_K1"));
    vec_push(refs, secret_ref_file("K2", "/tmp/secret", 384));
    var env = credential_proxy_env_vars(p, refs);
    assert_eq(vec_len(env), 2, "only ENV refs emitted (name+value)");
    assert_eq(streq(vec_get(env, 0), "MY_K1"), 1, "var name");
    assert_eq(streq(vec_get(env, 1), "v1"), 1, "var value");
    return 0;
}

fn test_credential_file_injections() {
    test_group("credential_file_injections");
    var p = credential_proxy_new();
    credential_proxy_register(p, "TLS_CERT", "-----CERT-----");
    var refs = vec_new();
    vec_push(refs, secret_ref_file("TLS_CERT", "/etc/ssl/cert.pem", 384));
    var files = credential_proxy_file_injections(p, refs);
    assert_eq(vec_len(files), 1, "one file injection");
    var f = vec_get(files, 0);
    assert_eq(streq(FileInjection_path(f), "/etc/ssl/cert.pem"), 1, "path");
    assert_eq(streq(FileInjection_content(f), "-----CERT-----"), 1, "content");
    assert_eq(FileInjection_mode(f), 384, "mode 0o600");
    return 0;
}

fn test_credential_stdin_payload() {
    test_group("credential_stdin_payload");
    var p = credential_proxy_new();
    credential_proxy_register(p, "PART1", "hello");
    credential_proxy_register(p, "PART2", "world");
    var refs = vec_new();
    vec_push(refs, secret_ref_stdin("PART1"));
    vec_push(refs, secret_ref_stdin("PART2"));
    var s = credential_proxy_stdin_payload(p, refs);
    assert(s != 0, "payload built");
    assert_eq(streq(s, "hello\nworld"), 1, "joined with newline");

    var empty_refs = vec_new();
    assert_eq(credential_proxy_stdin_payload(p, empty_refs), 0, "no refs -> 0");
    return 0;
}

fn test_audit_chain_record() {
    test_group("audit_chain_record");
    sha256_global_init();
    var c = audit_chain_open("/tmp/kavach-test-record.audit", "key-a", 5);
    assert_eq(audit_chain_len(c), 1, "genesis auto-recorded");
    audit_chain_record(c, "event1", "payload1");
    assert_eq(audit_chain_len(c), 2, "one more");
    audit_chain_record(c, "event2", "payload2");
    assert_eq(audit_chain_len(c), 3, "three total");
    return 0;
}

fn test_audit_chain_linkage() {
    test_group("audit_chain_linkage");
    sha256_global_init();
    var c = audit_chain_open("/tmp/kavach-test-link.audit", "key-b", 5);
    var e1 = audit_chain_record(c, "a", "p1");
    var e2 = audit_chain_record(c, "b", "p2");
    # e2.prev_hmac should equal e1.hmac
    assert_eq(streq(AuditEntry_prev_hmac(e2), AuditEntry_hmac(e1)), 1, "linked");
    assert(streq(AuditEntry_hmac(e1), AuditEntry_hmac(e2)) == 0, "distinct hmacs");
    return 0;
}

fn test_audit_entry_verify() {
    test_group("audit_verify");
    sha256_global_init();
    var c = audit_chain_open("/tmp/kavach-test-verify.audit", "mykey", 5);
    var e = audit_chain_record(c, "good", "clean payload");
    assert_eq(audit_entry_verify(e, "mykey", 5), 1, "correct key verifies");
    assert_eq(audit_entry_verify(e, "wrong", 5), 0, "wrong key fails");

    # Tamper the payload in place; verification must fail with original key.
    AuditEntry_set_payload(e, "tampered payload");
    assert_eq(audit_entry_verify(e, "mykey", 5), 0, "tamper detected");
    return 0;
}

fn test_dispatch_noop_registered() {
    test_group("dispatch_noop");
    kavach_init();
    assert_eq(backend_is_registered(Backend.NOOP), 1, "noop registered");
    assert_eq(backend_is_registered(Backend.PROCESS), 1, "process registered");
    # Untouched backends remain unregistered until added.
    assert_eq(backend_is_registered(Backend.GVISOR), 0, "gvisor not yet");
    return 0;
}

fn test_sandbox_exec_noop() {
    test_group("sandbox_exec_noop");
    kavach_init();
    var cfg = config_new();
    config_backend(cfg, Backend.NOOP);
    var sb = sandbox_create(cfg);
    sandbox_transition(sb, SandboxState.RUNNING);
    var r = sandbox_exec(sb, "echo hi");
    assert(r != 0, "noop pass verdict");
    assert_eq(ExecResult_exit_code(r), 0, "exit 0");
    return 0;
}

fn test_sandbox_exec_not_running_rejected() {
    test_group("sandbox_exec_state_guard");
    kavach_init();
    var cfg = config_new();
    config_backend(cfg, Backend.NOOP);
    var sb = sandbox_create(cfg);
    # Intentionally skip transition to RUNNING
    var r = sandbox_exec(sb, "echo hi");
    assert_eq(r, 0, "exec refused in CREATED state");
    return 0;
}

fn test_quarantine_store() {
    test_group("quarantine_store");
    var q = quarantine_storage_new("/tmp/kavach-test-quar");
    var sr = scan_result_new();
    ScanResult_set_verdict(sr, ScanVerdict.BLOCK);
    var id = quarantine_store(q, "blocked stdout", 14, sr, "sb-1");
    assert(id > 0, "id assigned");
    assert_eq(QuarantineStorage_next_id(q), id + 1, "counter advanced");
    return 0;
}

fn test_quarantine_status_names() {
    test_group("quarantine_status_names");
    assert_eq(streq(quarantine_status_name(QuarantineStatus.QUARANTINED), "quarantined"), 1, "q");
    assert_eq(streq(quarantine_status_name(QuarantineStatus.APPROVED), "approved"), 1, "a");
    assert_eq(streq(quarantine_status_name(QuarantineStatus.REJECTED), "rejected"), 1, "r");
    return 0;
}

fn test_process_backend_real_exec() {
    test_group("process_real_exec");
    kavach_init();
    var cfg = config_new();
    config_backend(cfg, Backend.NOOP);
    var sb = sandbox_create(cfg);
    # Directly call process_exec with /bin/echo (bypassing sandbox state guard)
    # to prove the fork+exec+capture pipeline actually runs.
    var r = process_exec(sb, "/bin/echo hello_from_process_backend");
    assert(r != 0, "exec returned a result");
    assert_eq(ExecResult_exit_code(r), 0, "exit 0");
    var out = ExecResult_stdout(r);
    assert(str_contains(out, "hello_from_process_backend") == 1, "stdout captured");
    return 0;
}

fn test_process_backend_rejects_bash() {
    test_group("process_rejects_bash");
    kavach_init();
    var cfg = config_new();
    config_backend(cfg, Backend.PROCESS);
    var sb = sandbox_create(cfg);
    var r = process_exec(sb, "/bin/bash -c whoami");
    assert(r != 0, "result returned");
    assert_eq(ExecResult_exit_code(r), 126, "blocklist exit code");
    var err = ExecResult_stderr(r);
    assert(str_contains(err, "blocked command") == 1, "blocklist message");
    return 0;
}

fn test_end_to_end_with_audit() {
    test_group("end_to_end_audit");
    kavach_init();
    sha256_global_init();
    var chain = audit_chain_open("/tmp/kavach-test-e2e.audit", "e2e-key", 7);
    sandbox_exec_set_audit_chain(chain);

    var cfg = config_new();
    config_backend(cfg, Backend.NOOP);
    var sb = sandbox_create(cfg);
    sandbox_transition(sb, SandboxState.RUNNING);

    var before = audit_chain_len(chain);
    sandbox_exec(sb, "ls /tmp");
    var after = audit_chain_len(chain);
    # Two audit entries per exec: exec_begin + exec_complete
    assert_eq(after - before, 2, "two audit entries per exec");

    sandbox_exec_set_audit_chain(0);
    return 0;
}

fn test_runtime_blocked_command() {
    test_group("runtime_blocked_cmd");
    var cfg = runtime_guard_config_default();
    var v = check_command("/bin/bash -c 'whoami'", cfg);
    assert(vec_len(v) >= 1, "bash blocked");
    var saw_blocked = 0;
    var i = 0;
    while (i < vec_len(v)) {
        var vio = vec_get(v, i);
        if (GuardViolation_violation_type(vio) == ViolationType.BLOCKED_COMMAND) {
            saw_blocked = 1;
        }
        i = i + 1;
    }
    assert_eq(saw_blocked, 1, "BLOCKED_COMMAND violation present");
    return 0;
}

fn test_runtime_allowed_command() {
    test_group("runtime_allowed_cmd");
    var cfg = runtime_guard_config_default();
    var v = check_command("ls -la /tmp", cfg);
    var saw_blocked = 0;
    var i = 0;
    while (i < vec_len(v)) {
        var vio = vec_get(v, i);
        if (GuardViolation_violation_type(vio) == ViolationType.BLOCKED_COMMAND) {
            saw_blocked = 1;
        }
        i = i + 1;
    }
    assert_eq(saw_blocked, 0, "ls not in blocklist");
    assert_eq(is_allowed_command("ls"), 1, "ls on allowlist");
    return 0;
}

fn test_runtime_sensitive_path() {
    test_group("runtime_sensitive_path");
    var cfg = runtime_guard_config_default();
    var v = check_command("cat /etc/shadow", cfg);
    assert(vec_len(v) >= 1, "sensitive path flagged");
    return 0;
}

fn test_runtime_shell_injection() {
    test_group("runtime_shell_injection");
    var cfg = runtime_guard_config_default();
    var v = check_command("echo hi; bash -c 'whoami'", cfg);
    assert(vec_len(v) >= 1, "shell injection flagged");
    return 0;
}

fn test_runtime_fork_bomb() {
    test_group("runtime_fork_bomb");
    var cfg = runtime_guard_config_default();
    assert_eq(check_fork_bomb(10, cfg), 0, "10 pids below limit");
    var vio = check_fork_bomb(100, cfg);
    assert(vio != 0, "100 pids over limit of 64");
    assert_eq(GuardViolation_violation_type(vio), ViolationType.FORK_BOMB, "fork_bomb type");
    return 0;
}

fn test_runtime_time_anomaly() {
    test_group("runtime_time_anomaly");
    var cfg = runtime_guard_config_default();
    # 1000ms expected, multiplier 2.0 → threshold 2000
    assert_eq(check_time_anomaly(1500, 1000, cfg), 0, "1500 under 2000");
    var vio = check_time_anomaly(3000, 1000, cfg);
    assert(vio != 0, "3000 > 2000 threshold");
    return 0;
}

fn test_threat_benign() {
    test_group("threat_benign");
    var findings = vec_new();
    var a = classify_threat(findings);
    assert_eq(ThreatAssessment_intent_score_x1000(a), 0, "empty = 0");
    assert_eq(ThreatAssessment_classification(a), ThreatTier.BENIGN, "benign");
    assert_eq(ThreatAssessment_escalation(a), EscalationTier.TIER1_LOG, "tier1");
    return 0;
}

fn test_threat_suspicious() {
    test_group("threat_suspicious");
    var findings = vec_new();
    # Single low-severity finding: weight 150, no amplifier -> 150 (suspicious range)
    vec_push(findings, finding_new("secrets", Severity.LOW, "pii", "minor", 0));
    vec_push(findings, finding_new("secrets", Severity.MEDIUM, "pii", "more", 0));
    var a = classify_threat(findings);
    # 150 + 350 = 500. One stage (pii → EXFILTRATION) → amplifier 1.0 → 500
    assert(ThreatAssessment_intent_score_x1000(a) >= 200, "suspicious+");
    return 0;
}

fn test_threat_malicious_coord() {
    test_group("threat_malicious_coordinated");
    # 3 critical findings across 3 stages → amplifier 1.5x → exceed 1.0
    var findings = vec_new();
    vec_push(findings, finding_new("secrets", Severity.CRITICAL, "private_key", "k", 0));
    vec_push(findings, finding_new("code", Severity.CRITICAL, "command_injection", "c", 0));
    vec_push(findings, finding_new("code", Severity.CRITICAL, "data_exfiltration", "d", 0));
    var a = classify_threat(findings);
    assert_eq(ThreatAssessment_classification(a), ThreatTier.MALICIOUS, "malicious");
    assert_eq(ThreatAssessment_escalation(a), EscalationTier.TIER4_REVOKE, "revoke");
    assert_eq(vec_len(ThreatAssessment_kill_chain_stages(a)), 3, "3 unique stages");
    return 0;
}

fn test_kill_chain_stage_names() {
    test_group("kill_chain_names");
    assert_eq(streq(kill_chain_stage_name(KillChainStage.RECONNAISSANCE), "reconnaissance"), 1, "recon");
    assert_eq(streq(kill_chain_stage_name(KillChainStage.EXFILTRATION), "exfiltration"), 1, "exfil");
    assert_eq(streq(threat_tier_name(ThreatTier.MALICIOUS), "malicious"), 1, "malicious");
    assert_eq(streq(escalation_tier_name(EscalationTier.TIER4_REVOKE), "tier4_revoke"), 1, "tier4");
    return 0;
}

fn test_verdict_determination() {
    test_group("verdict_determination");
    var pol = ext_policy_default();
    assert_eq(determine_verdict(Severity.INFO, pol), ScanVerdict.PASS, "info=pass");
    assert_eq(determine_verdict(Severity.LOW, pol), ScanVerdict.WARN, "low=warn");
    assert_eq(determine_verdict(Severity.HIGH, pol), ScanVerdict.QUARANTINE, "high=quarantine");
    assert_eq(determine_verdict(Severity.CRITICAL, pol), ScanVerdict.BLOCK, "critical=block");
    return 0;
}

fn test_scan_multiple() {
    test_group("scan_multiple");
