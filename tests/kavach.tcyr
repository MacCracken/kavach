    var er = exec_result_new();
    ExecResult_set_stdout(er, "hello world");
    var pol = ext_policy_default();
    var sr = gate_apply(er, pol);
    assert_eq(ScanResult_verdict(sr), ScanVerdict.PASS, "verdict pass");
    return 0;
}

fn test_gate_block_private_key() {
    test_group("gate_block_private_key");
    var er = exec_result_new();
    ExecResult_set_stdout(er, "-----BEGIN RSA PRIVATE KEY-----\nMIIEp...");
    var pol = ext_policy_default();
    var sr = gate_apply(er, pol);
    assert_eq(ScanResult_verdict(sr), ScanVerdict.BLOCK, "verdict block");
    assert_eq(ScanResult_worst_severity(sr), Severity.CRITICAL, "critical");
    return 0;
}

fn test_gate_size_limit() {
