fn test_data_ipv4_rejects_version() {
    test_group("data_ipv4_neg");
    var r = scan_result_new();
    data_scan("version 1.2.3 end", r);
    # 1.2.3 is not a full IPv4
    var v = ScanResult_findings(r);
    var i = 0;
    var found_ip = 0;
    while (i < vec_len(v)) {
        var f = vec_get(v, i);
        if (streq(ScanFinding_category(f), "pii_network") == 1) { found_ip = 1; }
        i = i + 1;
    }
    assert_eq(found_ip, 0, "1.2.3 is not IPv4");
    return 0;
}

