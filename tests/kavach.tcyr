fn test_scan_clean() {
    test_group("scan_clean");
    var r = scan_result_new();
    secrets_scan("hello world, this is clean output", r);
    assert_eq(vec_len(ScanResult_findings(r)), 0, "no findings");
    assert_eq(ScanResult_worst_severity(r), Severity.INFO, "worst stays info");
    return 0;
}

fn test_scan_aws_key() {
    test_group("scan_aws_key");
    var r = scan_result_new();
    secrets_scan("my key is AKIAIOSFODNN7EXAMPLE rest", r);
    var v = ScanResult_findings(r);
    assert(vec_len(v) >= 1, "at least one finding");
    var f = vec_get(v, 0);
    assert_eq(streq(ScanFinding_category(f), "cloud_credential"), 1, "cat cloud_credential");
    assert_eq(ScanFinding_severity(f), Severity.CRITICAL, "critical");
    assert_eq(ScanResult_worst_severity(r), Severity.CRITICAL, "worst=critical");
    return 0;
}

