fn test_scan_multiple() {
    test_group("scan_multiple");
    var r = scan_result_new();
    secrets_scan("key=AKIAIOSFODNN7EXAMPLE token=ghp_ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij", r);
