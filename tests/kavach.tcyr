    ExecResult_set_stdout(er, "this is longer than 10 bytes");
    var pol = ext_policy_default();
    ExternalizationPolicy_set_max_artifact_size_bytes(pol, 10);
    var sr = gate_apply(er, pol);
    assert_eq(ScanResult_verdict(sr), ScanVerdict.BLOCK, "oversized blocked");
    return 0;
}

