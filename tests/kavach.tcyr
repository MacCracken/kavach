fn test_backend_parse() {
    test_group("backend_parse");
    assert_eq(backend_parse("noop"), Backend.NOOP, "parse noop");
    assert_eq(backend_parse("process"), Backend.PROCESS, "parse process");
    assert_eq(backend_parse("firecracker"), Backend.FIRECRACKER, "parse firecracker");
    assert_eq(backend_parse("NOOP"), Backend.NOOP, "parse noop (case)");
    assert_eq(backend_parse("SyAgnos"), Backend.SY_AGNOS, "parse syagnos (mixed case)");
    assert_eq(backend_parse("sy-agnos"), Backend.SY_AGNOS, "parse sy-agnos");
    assert_eq(backend_parse("bogus"), 0 - 1, "unknown returns -1");
    return 0;
}

fn test_base_scores() {
    test_group("base_score");
    assert_eq(base_score(Backend.NOOP), 0, "noop 0");
    assert_eq(base_score(Backend.PROCESS), 50, "process 50");
    assert_eq(base_score(Backend.FIRECRACKER), 90, "firecracker 90");
    assert_eq(base_score(Backend.SY_AGNOS), 80, "syagnos base 80");
    return 0;
}

fn test_score_labels() {
    test_group("score_label");
    var l0 = score_label(0);
    var l29 = score_label(29);
    var l30 = score_label(30);
    var l50 = score_label(50);
    var l70 = score_label(70);
    var l85 = score_label(85);
    var l100 = score_label(100);
    assert_eq(streq(l0, "minimal"), 1, "0 minimal");
    assert_eq(streq(l29, "minimal"), 1, "29 minimal");
    assert_eq(streq(l30, "basic"), 1, "30 basic");
    assert_eq(streq(l50, "standard"), 1, "50 standard");
    assert_eq(streq(l70, "hardened"), 1, "70 hardened");
    assert_eq(streq(l85, "fortress"), 1, "85 fortress");
    assert_eq(streq(l100, "fortress"), 1, "100 fortress");
    return 0;
}

fn test_policy_presets() {
    test_group("policy_preset");
    var m = policy_minimal();
    assert_eq(SandboxPolicy_seccomp_enabled(m), 0, "minimal no seccomp");
    assert_eq(SandboxPolicy_read_only_rootfs(m), 0, "minimal not read-only");

    var b = policy_basic();
    assert_eq(SandboxPolicy_seccomp_enabled(b), 1, "basic has seccomp");
    assert_eq(SandboxPolicy_network_enabled(b), 0, "basic no network");

    var s = policy_strict();
    assert_eq(SandboxPolicy_seccomp_enabled(s), 1, "strict seccomp");
    assert_eq(SandboxPolicy_read_only_rootfs(s), 1, "strict read-only");
    assert_eq(SandboxPolicy_memory_limit_mb(s), 512, "strict mem 512");
    assert_eq(SandboxPolicy_max_pids(s), 64, "strict max_pids 64");
    assert_eq(SandboxPolicy_landlock_abstract_unix(s), 1, "strict scope abstract");
    assert_eq(SandboxPolicy_landlock_signal(s), 1, "strict scope signal");
    return 0;
}

fn test_policy_from_preset() {
    test_group("policy_from_preset");
    var s = policy_from_preset("STRICT");
    assert(s != 0, "STRICT parses");
    assert_eq(SandboxPolicy_read_only_rootfs(s), 1, "STRICT → strict");

    var b = policy_from_preset("Basic");
    assert(b != 0, "Basic parses");
    assert_eq(SandboxPolicy_seccomp_enabled(b), 1, "Basic → basic");

    var u = policy_from_preset("unknown");
    assert_eq(u, 0, "unknown → 0");
    return 0;
}

fn test_score_modifiers() {
    test_group("score_modifiers");
    # Minimal policy on Noop: network disabled adds +5.
    var m = policy_minimal();
    assert_eq(score_backend(Backend.NOOP, m), 5, "noop+minimal = 5");

    # Strict policy on Process: base 50 + seccomp 5 + no-net 5 + ro 3 + mem/cpu 2
    # + scope abstract 2 + scope signal 2 = 69
    var s = policy_strict();
    assert_eq(score_backend(Backend.PROCESS, s), 69, "process+strict = 69");

    # Firecracker clamped to 100 under strict.
    var f = score_backend(Backend.FIRECRACKER, s);
    assert(f <= 100, "firecracker clamped");
    assert(f >= 90, "firecracker >= base");
    return 0;
}

fn test_err_names() {
    test_group("error_names");
    assert_eq(streq(kavach_err_name(KavachError.OK), "ok"), 1, "OK → ok");
    assert_eq(streq(kavach_err_name(KavachError.TIMEOUT), "sandbox timeout"), 1, "TIMEOUT → sandbox timeout");
    assert_eq(streq(kavach_err_name(KavachError.POLICY_VIOLATION), "policy violation"), 1, "POLICY → policy violation");
    return 0;
}

fn test_state_transitions() {
    test_group("state_transitions");
    assert_eq(valid_transition(SandboxState.CREATED, SandboxState.RUNNING), 1, "created->running");
    assert_eq(valid_transition(SandboxState.RUNNING, SandboxState.PAUSED), 1, "running->paused");
    assert_eq(valid_transition(SandboxState.RUNNING, SandboxState.STOPPED), 1, "running->stopped");
    assert_eq(valid_transition(SandboxState.RUNNING, SandboxState.DESTROYED), 1, "running->destroyed");
    assert_eq(valid_transition(SandboxState.PAUSED, SandboxState.RUNNING), 1, "paused->running");
    assert_eq(valid_transition(SandboxState.PAUSED, SandboxState.DESTROYED), 1, "paused->destroyed");
    assert_eq(valid_transition(SandboxState.STOPPED, SandboxState.DESTROYED), 1, "stopped->destroyed");

    # Invalid edges
    assert_eq(valid_transition(SandboxState.CREATED, SandboxState.STOPPED), 0, "created->stopped bad");
    assert_eq(valid_transition(SandboxState.CREATED, SandboxState.DESTROYED), 0, "created->destroyed bad");
    assert_eq(valid_transition(SandboxState.DESTROYED, SandboxState.RUNNING), 0, "destroyed->running bad");
    assert_eq(valid_transition(SandboxState.STOPPED, SandboxState.RUNNING), 0, "stopped->running bad");
    return 0;
}

fn test_state_names() {
    test_group("state_names");
    assert_eq(streq(state_name(SandboxState.CREATED), "created"), 1, "created");
    assert_eq(streq(state_name(SandboxState.RUNNING), "running"), 1, "running");
    assert_eq(streq(state_name(SandboxState.DESTROYED), "destroyed"), 1, "destroyed");
    return 0;
}

fn test_config_defaults() {
    test_group("config_defaults");
    var c = config_new();
    assert_eq(SandboxConfig_backend(c), Backend.PROCESS, "default backend process");
    assert_eq(SandboxConfig_timeout_ms(c), 30000, "default timeout 30s");
    assert_eq(SandboxConfig_inner_backend(c), 0 - 1, "no inner backend");
    var p = SandboxConfig_policy(c);
    assert_eq(SandboxPolicy_seccomp_enabled(p), 1, "default policy basic (seccomp on)");
    return 0;
}

fn test_config_builder() {
    test_group("config_builder");
    var c = config_new();
    config_backend(c, Backend.GVISOR);
    config_policy_seccomp(c, "strict");
    config_network(c, 0);
    config_timeout_ms(c, 60000);
    config_agent_id(c, "agent-123");

    assert_eq(SandboxConfig_backend(c), Backend.GVISOR, "backend gvisor");
    assert_eq(SandboxConfig_timeout_ms(c), 60000, "timeout 60s");
    var p = SandboxConfig_policy(c);
    assert_eq(SandboxPolicy_seccomp_enabled(p), 1, "seccomp on");
    assert_eq(SandboxPolicy_network_enabled(p), 0, "network off");
    assert_eq(streq(SandboxConfig_agent_id(c), "agent-123"), 1, "agent id");
    return 0;
}

fn test_sandbox_create_and_transition() {
    test_group("sandbox_lifecycle");
    var c = config_new();
    config_backend(c, Backend.NOOP);
    var sb = sandbox_create(c);
    assert(sb != 0, "sandbox created");
    assert_eq(Sandbox_state(sb), SandboxState.CREATED, "initial state created");
    assert_eq(Sandbox_started_at(sb), 0, "started_at unset");

    assert_eq(sandbox_transition(sb, SandboxState.RUNNING), KavachError.OK, "start");
    assert_eq(Sandbox_state(sb), SandboxState.RUNNING, "state running");
    assert(Sandbox_started_at(sb) != 0, "started_at set");

    # Invalid jump running -> created
    assert_eq(sandbox_transition(sb, SandboxState.CREATED), KavachError.INVALID_TRANSITION, "running->created rejected");
    assert_eq(Sandbox_state(sb), SandboxState.RUNNING, "state unchanged on reject");

    assert_eq(sandbox_transition(sb, SandboxState.STOPPED), KavachError.OK, "stop");
    assert(Sandbox_stopped_at(sb) != 0, "stopped_at set");

    assert_eq(sandbox_transition(sb, SandboxState.DESTROYED), KavachError.OK, "destroy");
    assert_eq(Sandbox_state(sb), SandboxState.DESTROYED, "state destroyed");
    return 0;
}

fn test_sandbox_destroy_from_running() {
    test_group("sandbox_destroy");
    var c = config_new();
    config_backend(c, Backend.NOOP);
    var sb = sandbox_create(c);
    sandbox_transition(sb, SandboxState.RUNNING);
    assert_eq(sandbox_destroy(sb), KavachError.OK, "destroy from running");
    assert_eq(Sandbox_state(sb), SandboxState.DESTROYED, "destroyed");
    return 0;
}

fn test_sandbox_pool() {
    test_group("sandbox_pool");
    var c = config_new();
    config_backend(c, Backend.NOOP);
    var pool = sandbox_pool_new(c, 3);
    assert(pool != 0, "pool created");
    assert_eq(sandbox_pool_available(pool), 3, "3 warm");

    var s1 = sandbox_pool_claim(pool);
    assert(s1 != 0, "claim 1");
    assert_eq(sandbox_pool_available(pool), 2, "2 left");

    assert_eq(sandbox_pool_replenish(pool), KavachError.OK, "replenish");
    assert_eq(sandbox_pool_available(pool), 3, "refilled to 3");
    return 0;
}

fn test_severity_ordering() {
    test_group("severity_ordering");
    assert(Severity.INFO < Severity.LOW, "info < low");
    assert(Severity.LOW < Severity.MEDIUM, "low < medium");
    assert(Severity.MEDIUM < Severity.HIGH, "medium < high");
    assert(Severity.HIGH < Severity.CRITICAL, "high < critical");
    return 0;
}

