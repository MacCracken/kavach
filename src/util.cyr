# kavach — shared string helpers

fn ch_ascii_lower(c) {
    if (c >= 65) {
        if (c <= 90) { return c + 32; }
    }
    return c;
}

# Case-insensitive null-terminated string equality. 1 = equal, 0 = not.
fn strieq(a, b) {
    var i = 0;
    while (1 == 1) {
        var ca = load8(a + i);
        var cb = load8(b + i);
        if (ch_ascii_lower(ca) != ch_ascii_lower(cb)) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}
